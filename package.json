{
  "name": "@taulo1999/heyshorty",
  "version": "1.0.5",
  "description": "A global search modal",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --watch",
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm && tsc --emitDeclarationOnly"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@material/mwc-icon": "^0.27.0",
    "fuse.js": "^7.1.0",
    "hotkeys-js": "^4.0.2",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "prettier": "^3.8.1",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "lit": "^3.3.2"
  }
}
